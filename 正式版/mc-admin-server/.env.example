# 服务器配置
HOST=0.0.0.0
PORT=8000
DEBUG=false

# 安全配置
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 大模型API配置
ANTHROPIC_API_KEY=your-anthropic-api-key
MODEL_FLASH=MiMo-V2-Flash
MODEL_STANDARD=MiMo-V2-Omni
MODEL_PRO=mimo-v2-pro

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# 模组认证token（长度 >= 32 字符，生产用随机值）
MOD_AUTH_TOKEN=your-mod-token-change-in-production

# 未登记的 server_id 首次连接是否自动注册（生产建议 false，避免任意模组入库）
MOD_ALLOW_NEW_SERVERS=true

# CORS配置（可选，默认允许localhost:3000和5173）
# CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
